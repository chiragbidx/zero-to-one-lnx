{
  "$schema": "https://railpack.com/schema.json",
  "deploy": {
    "aptPackages": ["git"],
    "caches": {
      "npm-install": {
        "directory": "/root/.npm",
        "type": "shared"
      },
      "apt": {
        "directory": "/var/cache/apt",
        "type": "locked"
      }
    },
    "steps": {
      "install": {
        "caches": ["npm-install", "apt"],
        "commands": ["npm install"]
      }
    }
  }
}
